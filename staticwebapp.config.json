{
  "$schema": "https://json.schemastore.org/staticwebapp.config.json",
  "globalHeaders": {
    "Content-Security-Policy": "frame-ancestors https://krylivi.sharepoint.com https://*.sharepoint.com 'self'",
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "strict-origin-when-cross-origin",
    "Permissions-Policy": "geolocation=(), microphone=(), camera=()"
  },
  "routes": [
    {
      "route": "/assets/*",
      "headers": {
        "Cache-Control": "public, max-age=86400, must-revalidate"
      }
    },
    {
      "route": "/*.html",
      "headers": {
        "Cache-Control": "public, max-age=300, must-revalidate"
      }
    },
    {
      "route": "/en",
      "redirect": "/en/",
      "statusCode": 301
    },
    {
      "route": "/sv",
      "redirect": "/sv/",
      "statusCode": 301
    },
    {
      "route": "/no",
      "redirect": "/no/",
      "statusCode": 301
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*", "/*.{png,jpg,jpeg,gif,svg,ico,webp}"]
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html",
      "statusCode": 200
    }
  },
  "mimeTypes": {
    ".html": "text/html; charset=utf-8",
    ".css": "text/css; charset=utf-8",
    ".png": "image/png"
  }
}
